<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="18dp"
    android:id="@+id/cardQueueMember"
    app:cardElevation="2dp"
    app:strokeColor="#ECECEC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="13dp">

        <!-- Token Circle -->

        <TextView
            android:id="@+id/tvTokenNumber"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/token_circl"
            android:gravity="center"
            android:text="#25"
            android:textColor="#16A34A"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <!-- Name & Subtitle -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMemberName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="#0F1010"
                android:textSize="22sp"
               />



        </LinearLayout>

        <!-- Status Chip -->


        <!-- Arrow -->



        <!-- Badge -->

        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Waiting"
            android:textStyle="bold"
            android:textSize="13sp"
            android:background="@drawable/bg_status_waiting"
            android:textColor="#2563EB"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>